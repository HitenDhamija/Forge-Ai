# ForgeAI Backend - Environment Variables
# Copy this file to .env and fill in the values.

# Application
APP_NAME=ForgeAI
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true

# API
API_V1_PREFIX=/api/v1

# CORS - comma-separated origins
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# Database (async PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/forgeai
DATABASE_ECHO=false

# JWT Authentication
# Generate a secure secret with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Sentry (optional - leave empty to disable)
SENTRY_DSN=

# ============================================================
# AI Configuration (Ollama / Local Models)
# ============================================================
OLLAMA_BASE_URL=http://localhost:11434
AI_DEFAULT_MODEL=qwen2.5
AI_MAX_CONTEXT_LENGTH=4096
AI_MAX_RESPONSE_TOKENS=2048
AI_TEMPERATURE=0.7

# ============================================================
# Repository Intelligence
# ============================================================
REPO_MAX_REPOSITORY_SIZE_MB=500
REPO_MAX_FILE_SIZE_KB=1024
REPO_MAX_FILES_TO_ANALYZE=10000
REPO_GIT_TIMEOUT=60
REPO_TEMP_DIR=/tmp/forgeai/repos

# ============================================================
# Semantic Memory
# ============================================================
MEMORY_CHROMA_HOST=chromadb
MEMORY_CHROMA_PORT=8000
MEMORY_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
MEMORY_EMBEDDING_FALLBACK_MODEL=all-MiniLM-L6-v2
MEMORY_SEARCH_TOP_K=20
MEMORY_CONTEXT_MAX_TOKENS=4096
