# ForgeAI SMTP Email Configuration
# Set these as environment variables before starting the backend.
#
# Gmail setup:
#   1. Go to https://myaccount.google.com/apppasswords
#   2. Create an App Password (use "Mail" as the app)
#   3. Copy the 16-character password below
#
# PowerShell example:
#   $env:SMTP_USERNAME="your@gmail.com"
#   $env:SMTP_PASSWORD="abcd efgh ijkl mnop"
#   $env:SMTP_FROM_EMAIL="your@gmail.com"
#
# CMD example:
#   set SMTP_USERNAME=your@gmail.com
#   set SMTP_PASSWORD=abcd efgh ijkl mnop
#   set SMTP_FROM_EMAIL=your@gmail.com

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=ForgeAI
SMTP_USE_TLS=true

# Other providers:
# Outlook/Hotmail: SMTP_HOST=smtp-mail.outlook.com, SMTP_PORT=587
# Yahoo:           SMTP_HOST=smtp.mail.yahoo.com,    SMTP_PORT=587
# SendGrid:        SMTP_HOST=smtp.sendgrid.net,      SMTP_PORT=587
