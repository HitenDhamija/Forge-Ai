# ============================================================
# ForgeAI Docker Environment Variables
# ============================================================
# Copy this file to .env and update the values

# ============================================================
# PostgreSQL Configuration
# ============================================================
POSTGRES_USER=forgeai
POSTGRES_PASSWORD=forgeai_dev_password
POSTGRES_DB=forgeai
DATABASE_URL=postgresql+asyncpg://forgeai:forgeai_dev_password@postgres:5432/forgeai

# ============================================================
# Application Configuration
# ============================================================
APP_ENV=development
DEBUG=true
APP_NAME=ForgeAI
APP_VERSION=0.1.0
LOG_LEVEL=INFO

# ============================================================
# Security
# ============================================================
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================================
# CORS Configuration
# ============================================================
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ============================================================
# API Configuration
# ============================================================
API_V1_PREFIX=/api/v1
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ============================================================
# AI/ML Configuration (Optional)
# ============================================================
# OPENAI_API_KEY=sk-your-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# HUGGINGFACE_TOKEN=hf_your-token-here

# ============================================================
# AI Configuration (Ollama / Local Models)
# ============================================================
OLLAMA_BASE_URL=http://ollama:11434
AI_DEFAULT_MODEL=qwen2.5
AI_MAX_CONTEXT_LENGTH=4096
AI_MAX_RESPONSE_TOKENS=2048
AI_TEMPERATURE=0.7

# ============================================================
# Redis Configuration (Optional - for caching/queues)
# ============================================================
# REDIS_URL=redis://redis:6379/0

# ============================================================
# Repository Intelligence
# ============================================================
REPO_MAX_REPOSITORY_SIZE_MB=500
REPO_MAX_FILE_SIZE_KB=1024
REPO_MAX_FILES_TO_ANALYZE=10000
REPO_GIT_TIMEOUT=60
REPO_TEMP_DIR=/tmp/forgeai/repos

# ============================================================
# Semantic Memory
# ============================================================
MEMORY_CHROMA_HOST=chromadb
MEMORY_CHROMA_PORT=8000
MEMORY_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
MEMORY_EMBEDDING_FALLBACK_MODEL=all-MiniLM-L6-v2
MEMORY_SEARCH_TOP_K=20
MEMORY_CONTEXT_MAX_TOKENS=4096

# ============================================================
# Monitoring (Optional)
# ============================================================
# SENTRY_DSN=https://your-sentry-dsn
# ENABLE_METRICS=false
